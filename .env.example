COMPOSE_PROJECT_NAME=wealthfolio

# SERVER
WF_LISTEN_ADDR=0.0.0.0:8088
WF_DB_PATH=/data/wealthfolio.db
# Required when WF_AUTH_PASSWORD_HASH is set: the default "*" is rejected
# when auth is active. Add every URL you will access from (comma-separated),
# including your local browser.
WF_CORS_ALLOW_ORIGINS=http://localhost:24568

# SECURITY
# 32-byte base64 key used for secrets encryption and JWT signing.
# Generate with: openssl rand -base64 32
WF_SECRET_KEY=<INSERT_BASE64_32_BYTES>

# OPTIONAL - uncomment to require a password before accessing the web UI.
# Argon2id PHC string. Generate with:
#   printf 'your-password' | argon2 yoursalt16chars! -id -e
# Paste the full output wrapped in single quotes (the $ signs must not be
# interpolated by Compose).
# WF_AUTH_PASSWORD_HASH='$argon2id$v=19$...'
